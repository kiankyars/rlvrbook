#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

expected_chapters=(
  01-introduction.md
  02-outcome-verifiers.md
  03-process-verifiers.md
  04-learned-programmatic-and-hybrid-verifiers.md
  05-turning-checks-into-training-signal.md
  06-search-and-test-time-verification.md
  07-reward-hacking-proxy-misspecification-and-verifier-robustness.md
  08-faithfulness-confidence-and-what-verification-misses.md
  09-canonical-domains-math-code-and-formal-proof.md
  10-long-context-multimodal-and-agentic-rlvr.md
  11-open-problems-and-the-research-agenda.md
)

expected_appendices=(
  a-minimal-rl-and-post-training-background.md
  b-benchmarks-evals-and-contamination.md
  c-practical-verifier-design-checklist.md
)

for file in "${expected_chapters[@]}"; do
  if [[ ! -f "$ROOT/book/chapters/$file" ]]; then
    echo "missing chapter: $file" >&2
    exit 1
  fi
done

for file in "${expected_appendices[@]}"; do
  if [[ ! -f "$ROOT/book/appendices/$file" ]]; then
    echo "missing appendix: $file" >&2
    exit 1
  fi
done

configured_chapters=()
while IFS= read -r line; do
  configured_chapters+=("${line#chapters/}")
done < <(rg -o 'chapters/[0-9]{2}-[^"]+\.md' "$ROOT/book/_quarto.yml")

configured_appendices=()
while IFS= read -r line; do
  configured_appendices+=("${line#appendices/}")
done < <(rg -o 'appendices/[a-z]-[^"]+\.md' "$ROOT/book/_quarto.yml")

chapter_count="$(find "$ROOT/book/chapters" -maxdepth 1 -type f -name '*.md' | wc -l | tr -d ' ')"
appendix_count="$(find "$ROOT/book/appendices" -maxdepth 1 -type f -name '*.md' | wc -l | tr -d ' ')"

if [[ "$chapter_count" != "11" ]]; then
  echo "expected 11 chapter files, found $chapter_count" >&2
  exit 1
fi

if [[ "$appendix_count" != "3" ]]; then
  echo "expected 3 appendix files, found $appendix_count" >&2
  exit 1
fi

if [[ "${#configured_chapters[@]}" -ne 11 ]]; then
  echo "expected 11 configured chapters in book/_quarto.yml, found ${#configured_chapters[@]}" >&2
  exit 1
fi

if [[ "${#configured_appendices[@]}" -ne 3 ]]; then
  echo "expected 3 configured appendices in book/_quarto.yml, found ${#configured_appendices[@]}" >&2
  exit 1
fi

for i in "${!expected_chapters[@]}"; do
  if [[ "${configured_chapters[$i]}" != "${expected_chapters[$i]}" ]]; then
    echo "chapter order mismatch in book/_quarto.yml at position $((i + 1))" >&2
    exit 1
  fi
done

for i in "${!expected_appendices[@]}"; do
  if [[ "${configured_appendices[$i]}" != "${expected_appendices[$i]}" ]]; then
    echo "appendix order mismatch in book/_quarto.yml at position $((i + 1))" >&2
    exit 1
  fi
done

echo "book scaffold looks consistent"
